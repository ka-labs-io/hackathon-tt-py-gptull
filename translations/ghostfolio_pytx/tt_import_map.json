{
  "imports": {
    "@ghostfolio/api/app/portfolio/calculator/portfolio-calculator": "app.wrapper.portfolio.calculator.portfolio_calculator",
    "@ghostfolio/api/app/portfolio/interfaces/portfolio-order-item.interface": "app.implementation.portfolio.interfaces.portfolio_order_item",
    "@ghostfolio/api/helper/portfolio.helper": "app.implementation.helpers.portfolio_helper",
    "@ghostfolio/common/calculation-helper": "app.implementation.helpers.calculation_helper",
    "@ghostfolio/common/helper": "app.implementation.helpers.common_helper",
    "@ghostfolio/common/interfaces": "app.implementation.interfaces",
    "@ghostfolio/common/models": "app.implementation.models",
    "@ghostfolio/common/types": "app.implementation.types",
    "@ghostfolio/common/types/performance-calculation-type.type": "app.implementation.types.performance_calculation_type",
    "@nestjs/common": null
  },
  "types": {
    "PortfolioCalculator": "PortfolioCalculator",
    "PortfolioOrderItem": "dict",
    "PortfolioSnapshot": "dict",
    "TimelinePosition": "dict",
    "AssetProfileIdentifier": "dict",
    "SymbolMetrics": "dict",
    "DateRange": "str",
    "PerformanceCalculationType": "str",
    "Logger": null
  },
  "libraries": {
    "big.js": {
      "module": "decimal",
      "mappings": { "Big": "Decimal" },
      "methods": {
        "plus": "__add__", "minus": "__sub__", "times": "__mul__", "div": "__truediv__",
        "eq": "__eq__", "gt": "__gt__", "gte": "__ge__", "lt": "__lt__", "lte": "__le__",
        "toNumber": "float", "abs": "abs", "round": "quantize"
      },
      "constructor": "Decimal"
    },
    "date-fns": {
      "module": "app.implementation.helpers.date_utils",
      "mappings": {
        "addMilliseconds": "add_milliseconds",
        "differenceInDays": "difference_in_days",
        "eachYearOfInterval": "each_year_of_interval",
        "format": "format_date",
        "isBefore": "is_before",
        "isThisYear": "is_this_year"
      }
    },
    "lodash": {
      "module": null,
      "mappings": { "cloneDeep": "copy.deepcopy", "sortBy": "sorted" }
    }
  },
  "utilities": {
    "getFactor": {
      "module": "app.implementation.helpers.portfolio_helper",
      "python_name": "get_factor"
    },
    "getIntervalFromDateRange": {
      "module": "app.implementation.helpers.calculation_helper",
      "python_name": "get_interval_from_date_range"
    }
  },
  "engine": {
    "module": "app.implementation.helpers.compute_engine",
    "functions": ["compute_snapshot", "make_performance_response", "make_investments_response", "make_holdings_response", "make_details_response", "make_dividends_response", "make_report_response"]
  },
  "adapters": {
    "get_performance": {
      "params": "self",
      "delegate": "return make_performance_response(self, compute_snapshot(self))"
    },
    "get_investments": {
      "params": "self, group_by=None",
      "delegate": "return make_investments_response(self, compute_snapshot(self), group_by)"
    },
    "get_holdings": {
      "params": "self",
      "delegate": "return make_holdings_response(self, compute_snapshot(self))"
    },
    "get_details": {
      "params": "self, base_currency='USD'",
      "delegate": "return make_details_response(self, compute_snapshot(self), base_currency)"
    },
    "get_dividends": {
      "params": "self, group_by=None",
      "delegate": "return make_dividends_response(self, compute_snapshot(self), group_by)"
    },
    "evaluate_report": {
      "params": "self",
      "delegate": "return make_report_response(self)"
    }
  },
  "constants": {
    "DATE_FORMAT": "yyyy-MM-dd"
  },
  "class_inheritance": {
    "RoaiPortfolioCalculator": "PortfolioCalculator"
  }
}
